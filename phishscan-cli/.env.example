# PhishScan API Keys — copy this file to .env and fill in your keys
# The .env file is git-ignored and must never be committed to the repository.

# VirusTotal v3 API key
# Get yours at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# isMalicious API credentials
# Get yours at: https://ismalicious.com/
ISMALICIOUS_API_KEY=your_ismalicious_api_key_here
ISMALICIOUS_API_SECRET=your_ismalicious_api_secret_here

# AbuseIPDB API key
# Get yours at: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
